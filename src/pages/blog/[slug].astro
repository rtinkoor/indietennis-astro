---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { posts, type BlogPost } from '../../data/posts';

export function getStaticPaths() {
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;

const formattedDate = new Date(post.publishedDate).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});

const canonicalUrl = `https://www.indietennis.com/blog/${post.slug}`;

const articleSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.title,
  description: post.metaDescription,
  author: {
    '@type': 'Organization',
    name: post.author,
    url: 'https://www.indietennis.com',
  },
  publisher: {
    '@type': 'Organization',
    name: 'IndieTennis',
    url: 'https://www.indietennis.com',
  },
  datePublished: post.publishedDate,
  dateModified: post.updatedDate ?? post.publishedDate,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalUrl,
  },
});

const contentBlocks = post.content.trim().split('\n\n');
---

<BaseLayout
  title={post.metaTitle}
  description={post.metaDescription}
  canonicalUrl={canonicalUrl}
  ogType="article"
  datePublished={post.publishedDate}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={articleSchema} />
  </Fragment>

  <Header />

  <main class="relative min-h-screen pt-32 pb-16">
    <img
      src="/court-background-optimized.webp"
      alt="Tennis court background"
      width={1920}
      height={1080}
      loading="eager"
      fetchpriority="high"
      decoding="async"
      class="absolute inset-0 -z-10 w-full h-full object-cover"
    />

    <div class="container mx-auto px-4 max-w-2xl">
      <div class="bg-black/80 backdrop-blur-sm rounded-2xl p-8 md:p-12 border border-white/10">

        <!-- Breadcrumb -->
        <nav class="text-sm text-white/40 mb-8 font-['Verdana',_sans-serif]">
          <a href="/" class="hover:text-white/70 transition-colors">Home</a>
          <span class="mx-2">›</span>
          <a href="/blog" class="hover:text-white/70 transition-colors">Blog</a>
          <span class="mx-2">›</span>
          <span class="text-white/60">{post.title}</span>
        </nav>

        <!-- Category -->
        <div class="mb-4">
          <span class="text-xs font-semibold uppercase tracking-widest text-yellow-500 font-['Verdana',_sans-serif]">
            {post.category}
          </span>
        </div>

        <!-- Title -->
        <h1 class="text-3xl md:text-4xl font-bold text-white leading-tight mb-4 font-['Trebuchet_MS',_sans-serif]">
          {post.title}
        </h1>

        <!-- Byline -->
        <div class="flex items-center gap-4 text-sm text-white/40 mb-10 border-b border-white/10 pb-6 font-['Verdana',_sans-serif]">
          <span>{post.author}</span>
          <span>·</span>
          <time datetime={post.publishedDate}>{formattedDate}</time>
        </div>

        <!-- Article body -->
        <article class="font-['Verdana',_sans-serif] text-sm leading-relaxed">
          {contentBlocks.map((block) => {
            if (block.startsWith('## ')) {
              return (
                <h2 class="text-2xl font-bold text-white mt-10 mb-4 font-['Trebuchet_MS',_sans-serif]">
                  {block.replace('## ', '')}
                </h2>
              );
            }
            if (block.startsWith('### ')) {
              return (
                <h3 class="text-xl font-semibold text-white mt-8 mb-3 font-['Trebuchet_MS',_sans-serif]">
                  {block.replace('### ', '')}
                </h3>
              );
            }
            if (block.startsWith('---')) {
              return <hr class="my-8 border-white/20" />;
            }
            return (
              <p class="mb-5 text-white/70 leading-relaxed">
                {block.replace(/\*\*/g, '')}
              </p>
            );
          })}
        </article>

        <!-- Tags -->
        <div class="mt-12 pt-6 border-t border-white/10 flex flex-wrap gap-2">
          {post.tags.map((tag) => (
            <span class="text-xs px-3 py-1 bg-white/10 rounded-full text-white/50 font-['Verdana',_sans-serif]">
              {tag}
            </span>
          ))}
        </div>

        <!-- Back link -->
        <div class="mt-8">
          <a href="/blog" class="text-sm text-[hsl(75,65%,50%)] hover:text-[hsl(75,65%,60%)] transition-colors font-['Verdana',_sans-serif]">
            ← Back to all posts
          </a>
        </div>

      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
