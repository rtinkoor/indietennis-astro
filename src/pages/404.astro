---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Page Not Found — IndieTennis"
  description="The page you're looking for doesn't exist. Return to IndieTennis, the independent tennis network."
>
  <div class="min-h-screen relative flex flex-col">
    <img
      src="/court-background.webp"
      alt="Tennis court background"
      width={1920}
      height={1080}
      loading="eager"
      decoding="async"
      class="fixed inset-0 -z-10 w-full h-full object-cover"
    />
    <Header />
    <main class="flex-1 flex items-center justify-center pt-32 pb-16">
      <div class="text-center">
        <h1 class="text-white text-5xl font-bold mb-4 font-['Trebuchet_MS',_sans-serif]">404</h1>
        <p class="text-white/70 text-xl mb-8 font-['Verdana',_sans-serif]">Page not found</p>
        <a
          href="/"
          class="inline-block px-6 py-3 bg-[hsl(75,65%,50%)] text-[hsl(0,0%,15%)] font-bold rounded-lg hover:bg-[hsl(75,65%,55%)] transition-colors font-['Trebuchet_MS',_sans-serif]"
        >
          Return Home
        </a>
      </div>
    </main>
    <Footer />
  </div>
</BaseLayout>
